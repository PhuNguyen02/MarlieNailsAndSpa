{
  "compilerOptions": {
    // Use CommonJS module system for NestJS compatibility
    "module": "commonjs",

    // Target a stable Node-compatible ECMAScript version
    "target": "ES2017",

    // Emit metadata required for decorators (NestJS)
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    // Interop and module resolution
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Output settings
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,

    // Type-checking options
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
